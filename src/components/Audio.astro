---
import "~/styles/audio.css";
---

<audio id="background-audio"> </audio>

<button
  class="music-toggle-btn"
  id="music-toggle-btn"
  aria-label="Toggle music player"
>
  <svg
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <path d="M9 18V5l12-2v13"></path>
    <circle cx="6" cy="18" r="3"></circle>
    <circle cx="18" cy="16" r="3"></circle>
  </svg>
</button>

<div class="music-player" id="music-player">
  <button
    class="close-btn"
    id="close-player-btn"
    aria-label="Close music player"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <div class="player-content">
    <div class="album-cover">
      <img src="" alt="" id="album-image" />
    </div>

    <div class="song-info">
      <div class="song-title" id="song-title">Loading...</div>
      <div class="song-artist" id="song-artist">Please wait...</div>
    </div>

    <div class="player-controls">
      <button class="control-btn" id="prev-btn">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polygon points="19,20 9,12 19,4"></polygon>
          <line x1="5" y1="19" x2="5" y2="5"></line>
        </svg>
      </button>

      <button class="control-btn play-pause" id="play-pause-btn">
        <svg
          class="play-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polygon points="5,3 19,12 5,21"></polygon>
        </svg>
        <svg
          class="pause-icon hidden"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="6" y="4" width="4" height="16"></rect>
          <rect x="14" y="4" width="4" height="16"></rect>
        </svg>
      </button>

      <button class="control-btn" id="next-btn">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polygon points="5,4 15,12 5,20"></polygon>
          <line x1="19" y1="5" x2="19" y2="19"></line>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  import { showToast } from "~/components/ui/toast";
  import { songs } from "~/data/songs";
  import mobile from "is-mobile";
  
  const isMobile = mobile();

  const audio = document.getElementById("background-audio") as HTMLAudioElement;
  audio.volume = 0.3;

  const musicPlayer = document.getElementById("music-player");
  const musicToggleBtn = document.getElementById("music-toggle-btn");
  const closePlayerBtn = document.getElementById("close-player-btn");
  const playPauseBtn = document.getElementById("play-pause-btn");
  const playIcon = playPauseBtn?.querySelector(".play-icon");
  const pauseIcon = playPauseBtn?.querySelector(".pause-icon");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");

  let currentSongIndex = Math.floor(Math.random() * songs.length);
  let isPlaying = false;

  function updateSongInfo() {
    const currentSong = songs[currentSongIndex];
    const songTitle = document.getElementById("song-title");
    const songArtist = document.getElementById("song-artist");
    const albumImage = document.getElementById(
      "album-image",
    ) as HTMLImageElement;

    if (songTitle) songTitle.textContent = currentSong.title;
    if (songArtist) songArtist.textContent = currentSong.artist;
    if (albumImage) {
      albumImage.src = currentSong.cover;
      albumImage.alt = currentSong.title;
    }

    if (audio) {
      audio.src = currentSong.file;
      audio.load();
    }
  }

  function toastAudioStarted() {
    if (isMobile) return;

    showToast({
      title: "🎵 Audio Started",
      variant: "success",
      duration: 700,
    });
  }

  function togglePlayPause() {
    if (audio) {
      if (audio.paused) {
        audio
          .play()
          .then(() => {
            isPlaying = true;
            playIcon?.classList.add("hidden");
            pauseIcon?.classList.remove("hidden");
            toastAudioStarted();
          })
          .catch(console.error);
      } else {
        audio.pause();
        isPlaying = false;
        playIcon?.classList.remove("hidden");
        pauseIcon?.classList.add("hidden");
      }
    }
  }

  function nextSong() {
    const wasPlaying = !audio?.paused;
    currentSongIndex = (currentSongIndex + 1) % songs.length;
    updateSongInfo();

    if (wasPlaying && audio) {
      audio.addEventListener(
        "loadeddata",
        () => {
          audio.play().catch(console.error);
        },
        { once: true },
      );
    }
  }

  function prevSong() {
    const wasPlaying = !audio?.paused;
    currentSongIndex = (currentSongIndex - 1 + songs.length) % songs.length;
    updateSongInfo();

    if (wasPlaying && audio) {
      audio.addEventListener(
        "loadeddata",
        () => {
          audio.play().catch(console.error);
        },
        { once: true },
      );
    }
  }

  function showPlayer() {
    musicPlayer?.classList.add("visible");
    musicPlayer?.classList.add("expanded");
    musicToggleBtn?.classList.add("hidden");
  }

  function hidePlayer() {
    musicPlayer?.classList.remove("expanded");
    musicToggleBtn?.classList.remove("hidden");
  }

  updateSongInfo();

  playPauseBtn?.addEventListener("click", togglePlayPause);
  nextBtn?.addEventListener("click", nextSong);
  prevBtn?.addEventListener("click", prevSong);
  closePlayerBtn?.addEventListener("click", hidePlayer);
  musicToggleBtn?.addEventListener("click", showPlayer);

  window.addEventListener("backgroundLoaded", () => {
    if (!isMobile) {
      musicPlayer?.classList.add("visible");
    } else {
      musicToggleBtn?.classList.remove("hidden");
    }
  });

  audio?.addEventListener("ended", () => {
    console.log("Song ended, auto-playing next song");
    currentSongIndex = (currentSongIndex + 1) % songs.length;
    updateSongInfo();

    audio.addEventListener(
      "loadeddata",
      () => {
        audio.play().catch(console.error);
      },
      { once: true },
    );
  });

  audio?.addEventListener("pause", () => {
    isPlaying = false;
    playIcon?.classList.remove("hidden");
    pauseIcon?.classList.add("hidden");
  });

  audio?.addEventListener("play", () => {
    isPlaying = true;
    playIcon?.classList.add("hidden");
    pauseIcon?.classList.remove("hidden");
  });
</script>
