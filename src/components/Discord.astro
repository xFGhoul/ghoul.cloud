---
import "~/styles/discord.css";
---

<div class="glass-card discord-card">
  <div class="discord-content">
    <div class="discord-header">
      <div class="avatar-wrapper">
        <img id="avatar" class="discord-avatar" src="" fetchpriority="high" />
        <img
          id="status-indicator"
          class="status-indicator"
          src=""
          fetchpriority="high"
        />
      </div>
      <div class="discord-user-info" id="margin">
        <h3 id="display" class="discord-display-name"></h3>
        <p id="username" class="discord-username"></p>
      </div>
    </div>

    <div class="activities-section">
      <div class="activities"></div>
      <div class="no-activities" id="no-activities" style="display: none;">
        <span>💤</span>
      </div>
    </div>
  </div>
</div>

<script>
  import { lanyard } from "~/lib/lanyard";
  import { config } from "~/config/config";
  import { formatTime } from "~/lib/utils";
  import { statusIcons, getPfpUrl } from "~/data/discord";

  let acts: any[] = [];

  const loadImage = (img: HTMLImageElement, src: string): Promise<void> => {
    return new Promise((resolve, reject) => {
      img.onload = () => {
        img.classList.add("loaded");
        img.parentElement?.classList.add("loaded");
        resolve();
      };
      img.onerror = reject;
      img.src = src;
    });
  };

  const updateStatus = (status: string) => {
    const statusIndicator = document.getElementById(
      "status-indicator",
    ) as HTMLImageElement;
    if (statusIndicator) {
      loadImage(statusIndicator, statusIcons[status] || statusIcons.offline);
    }
  };

  const load = () => {
    lanyard({
      userID: config.discord.id,
      socket: true,
      onPresenceUpdate: update,
    });
  };

  const update = (data: any) => {
    acts = data.activities;

    updateStatus(data.discord_status);
    draw(data);
  };

  const draw = async (data: any) => {
    const displayNameElem = document.getElementById("display");
    if (displayNameElem) {
      displayNameElem.innerText = data.discord_user.global_name;
    }

    const nameElem = document.getElementById("username");
    if (nameElem) {
      nameElem.innerText = data.discord_user.username;
    }

    const avaElem = document.getElementById("avatar") as HTMLImageElement;
    if (avaElem) {
      await loadImage(
        avaElem,
        getPfpUrl(
          data.discord_user.id,
          data.discord_user.discriminator,
          data.discord_user.avatar,
        ),
      );
    }

    const actsWrapper = document.querySelector(".activities");
    const noActivities = document.getElementById("no-activities");

    if (!actsWrapper) return;

    const toRemove: ChildNode[] = [];
    actsWrapper.childNodes.forEach((node: ChildNode) => {
      if (
        node instanceof HTMLElement &&
        acts.filter((act) => act.id == node.id).length === 0
      ) {
        toRemove.push(node);
      }
    });
    toRemove.forEach((node) => actsWrapper.removeChild(node));

    const visibleActivities = acts.filter((act) => act.type !== 4);

    if (visibleActivities.length === 0) {
      if (noActivities) noActivities.style.display = "flex";
      return;
    } else {
      if (noActivities) noActivities.style.display = "none";
    }

    acts.forEach(async (act: any) => {
      if (act.type === 4) return;

      if (document.getElementById(act.id)) return;

      const isSpotify = act.id === "spotify:1" && data.spotify;

      const actElem = document.createElement("div");
      actElem.classList.add("activity");
      actElem.id = act.id;

      const actHeader = document.createElement("div");
      actHeader.classList.add("activity-header");

      const actType = document.createElement("span");
      actType.classList.add("activity-type");
      actType.innerText = isSpotify ? "Listening to Spotify" : "Playing";

      actHeader.appendChild(actType);
      actElem.appendChild(actHeader);

      const actContent = document.createElement("div");
      actContent.classList.add("activity-content");

      const actImageWrapper = document.createElement("div");
      actImageWrapper.classList.add("act-images");

      const largeImageElem = document.createElement("img");
      largeImageElem.classList.add("largeimage");
      largeImageElem.draggable = false;

      if (isSpotify) {
        largeImageElem.src = data.spotify.album_art_url;
      } else {
        if (act.assets && act.assets.large_image) {
          largeImageElem.src = `${config.discord.urls.assets}/${act.application_id}/${act.assets.large_image}.png`;
        } else {
          largeImageElem.src = `${config.discord.urls.alternative}/${act.application_id}`;
        }
      }
      actImageWrapper.appendChild(largeImageElem);

      if ((act.assets && act.assets.small_image) || isSpotify) {
        const smallImageElem = document.createElement("img");
        smallImageElem.classList.add("smallimage");
        smallImageElem.draggable = false;
        if (isSpotify) {
          smallImageElem.src = config.discord.urls.spotify;
        } else {
          smallImageElem.src = `${config.discord.urls.assets}/${act.application_id}/${act.assets.small_image}.png`;
        }
        actImageWrapper.appendChild(smallImageElem);
      }

      actContent.appendChild(actImageWrapper);

      const actDetails = document.createElement("div");
      actDetails.classList.add("activity-details");

      const nameSpan = document.createElement("div");
      nameSpan.classList.add("act-name");
      const detailsSpan = document.createElement("div");
      detailsSpan.classList.add("act-details");
      const stateSpan = document.createElement("div");
      stateSpan.classList.add("act-state");

      if (isSpotify) {
        nameSpan.innerText = data.spotify.song;
        stateSpan.innerText = data.spotify.artist;

        actDetails.appendChild(nameSpan);
        actDetails.appendChild(stateSpan);

        if (data.spotify.timestamps) {
          const progressWrapper = document.createElement("div");
          progressWrapper.classList.add("spotify-progress");

          const timeStart = document.createElement("span");
          timeStart.classList.add("time-start");
          const timeEnd = document.createElement("span");
          timeEnd.classList.add("time-end");

          const progressBar = document.createElement("div");
          progressBar.classList.add("progress-bar");
          const progressFill = document.createElement("div");
          progressFill.classList.add("progress-fill");
          progressBar.appendChild(progressFill);

          const updateProgress = () => {
            const now = Date.now();
            const elapsed = now - data.spotify.timestamps.start;
            const total =
              data.spotify.timestamps.end - data.spotify.timestamps.start;
            const percent = Math.min((elapsed / total) * 100, 100);

            progressFill.style.width = `${percent}%`;
            timeStart.innerText = formatTime(elapsed);
            timeEnd.innerText = formatTime(total);
          };

          updateProgress();
          setInterval(updateProgress, 1000);

          progressWrapper.appendChild(timeStart);
          progressWrapper.appendChild(progressBar);
          progressWrapper.appendChild(timeEnd);
          actDetails.appendChild(progressWrapper);
        }
      } else {
        nameSpan.innerText = act.name || "";

        if (act.details) {
          detailsSpan.innerHTML = `${act.details}`;
        }

        if (act.state) {
          stateSpan.innerHTML = `${act.state}`;
        }

        actDetails.appendChild(nameSpan);
        actDetails.appendChild(detailsSpan);
        actDetails.appendChild(stateSpan);
      }

      actContent.appendChild(actDetails);
      actElem.appendChild(actContent);

      actsWrapper.appendChild(actElem);
    });
  };

  window.addEventListener("load", load);
</script>
