---
export interface Props {
  size?: "small" | "medium" | "large";
  text?: string;
  className?: string;
}

const { size = "medium", text = "Loading...", className = "" } = Astro.props;

const sizeClasses = {
  small: "spinner-small",
  medium: "spinner-medium",
  large: "spinner-large",
};
---

<div class={`spinner-container ${sizeClasses[size]} ${className}`}>
  <div class="simple-spinner"></div>
  <div class="loading-text">{text}</div>
</div>

<style>
  .spinner-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .simple-spinner {
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-top: 3px solid #ffffff;
    animation: spin 1s linear infinite;
  }

  .spinner-small .simple-spinner {
    width: 24px;
    height: 24px;
    border-width: 2px;
  }

  .spinner-medium .simple-spinner {
    width: 40px;
    height: 40px;
    border-width: 3px;
  }

  .spinner-large .simple-spinner {
    width: 56px;
    height: 56px;
    border-width: 4px;
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .loading-text {
    font-family: "Arial", sans-serif;
    color: #ffffff;
    opacity: 0.8;
  }

  .spinner-small .loading-text {
    font-size: 0.75rem;
  }

  .spinner-medium .loading-text {
    font-size: 1rem;
  }

  .spinner-large .loading-text {
    font-size: 1.25rem;
  }
</style>
