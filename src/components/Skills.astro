---
import "~/styles/glass.css";
import "~/styles/skills.css";

const tools = [
  { name: "Python", icon: "/icons/python.svg" },
  { name: "C++", icon: "/icons/cpp.svg" },
  { name: "TypeScript", icon: "/icons/typescript.svg" },
  { name: "Rust", icon: "/icons/rust.svg" },
  { name: "React", icon: "/icons/react.svg" },
  { name: "PostgreSQL", icon: "/icons/postgresql.svg" },
  { name: "Redis", icon: "/icons/redis.svg" },
  { name: "Linux", icon: "/icons/linux.svg" },
  { name: "Tailwind", icon: "/icons/tailwindcss.svg" },
  { name: "Docker", icon: "/icons/docker.svg" },
  { name: "Digital Ocean", icon: "/icons/digitalocean.svg"},
  { name: "Github", icon: "/icons/github.svg" },
  { name: "Git", icon: "/icons/git.svg" },
  { name: "Windows", icon: "/icons/windows.svg" },
  { name: "Visual Studio Code", icon: "/icons/vscode-insiders.svg" },
];
---

<div class="glass-card skills-card">
  <h3 class="card-title">Skills & Tools</h3>
  <div class="skills-grid">
    {tools.map((tool) => (
      <div class="skill-item">
        <img src={tool.icon} alt={tool.name} class="skill-icon" />
        <span class="skill-name">{tool.name}</span>
      </div>
    ))}
  </div>
</div>