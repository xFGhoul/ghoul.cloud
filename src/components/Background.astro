---

---

<div class="loading-spinner" id="loading-spinner">
  <div class="dots-spinner">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>
</div>

<div class="background" id="background" style="opacity: 0;">
  <video
    src="gojo.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    id="background-gif"></video>
</div>

<style>
  .loading-spinner {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    background: #1a1a1a;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    opacity: 1;
    transition: opacity 0.5s ease-in-out;
  }

  .loading-spinner.fade-out {
    opacity: 0;
  }

  .dots-spinner {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #fff;
    animation: bounce 1.4s ease-in-out infinite both;
  }

  .dot:nth-child(1) {
    animation-delay: -0.32s;
  }

  .dot:nth-child(2) {
    animation-delay: -0.16s;
  }

  .dot:nth-child(3) {
    animation-delay: 0s;
  }

  @keyframes bounce {
    0%,
    80%,
    100% {
      transform: scale(0) translateY(0);
      opacity: 0.5;
    }
    40% {
      transform: scale(1) translateY(-20px);
      opacity: 1;
    }
  }

  .background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.5s ease-in-out 0.1s;
  }

  .background.fade-in {
    opacity: 0.6;
  }

  .background video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  import { showToast } from "~/components/ui/toast";

  const spinner = document.getElementById("loading-spinner");
  const background = document.getElementById("background");

  setTimeout(() => {
    if (spinner && spinner.style.display !== "none") {
      spinner.style.display = "none";

      if (background) {
        background.style.opacity = "0.6";
      }

      showToast({
        title: "🍱 Background Loaded",
        variant: "success",
        duration: 700,
      });

      window.dispatchEvent(new CustomEvent("backgroundLoaded"));
    }
  }, 100);
</script>
