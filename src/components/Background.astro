---
import "~/styles/background.css";
---

<div class="loading-spinner" id="loading-spinner">
  <div class="spinner"></div>
</div>

<div class="background" id="background">
  <video autoplay muted loop playsinline preload="auto" id="background-video"
  ></video>
</div>

<script>
  import { showToast } from "~/components/ui/toast";
  import { config } from "~/config/config";
  import store from "~/lib/store";
  import mobile from "is-mobile";

  type Theme = "light" | "dark";

  const isMobile = mobile();
  const spinner = document.getElementById("loading-spinner");
  const background = document.getElementById("background");
  const video = document.getElementById("background-video") as HTMLVideoElement;

  let isTransitioning = false;

  function waitForEvent(target: EventTarget, name: string) {
    return new Promise<void>((resolve, reject) => {
      const onOk = () => {
        cleanup();
        resolve();
      };
      const onErr = () => {
        cleanup();
        reject(new Error(`Video event error while waiting for: ${name}`));
      };
      const cleanup = () => {
        target.removeEventListener(name, onOk as EventListener);
        target.removeEventListener("error", onErr as EventListener);
      };

      target.addEventListener(name, onOk as EventListener, { once: true });
      target.addEventListener("error", onErr as EventListener, { once: true });
    });
  }

  async function getVideoSource(theme: Theme): Promise<string> {
    if (isMobile) {
      return theme === "dark"
        ? config.background.mobileDark
        : config.background.mobile;
    }
    return theme === "dark"
      ? config.background.videoDark
      : config.background.video;
  }

  async function setVideoSrcPreserveTime(newSrc: string) {
    if (!video) return;

    const prevTime = Number.isFinite(video.currentTime) ? video.currentTime : 0;

    video.pause();
    video.src = newSrc;
    video.load();

    await waitForEvent(video, "loadedmetadata");
    const dur = Number.isFinite(video.duration) ? video.duration : 0;
    const clamped = dur > 0 ? Math.min(prevTime, Math.max(dur - 0.25, 0)) : 0;

    try {
      video.currentTime = clamped;
    } catch {
      // ignore seek failures
    }

    await waitForEvent(video, "canplay");
    await video.play().catch(console.error);
  }

  async function updateVideo() {
    if (isTransitioning || !video) return;

    const theme = (await store.getItem<Theme>("theme")) || "light";
    const newSrc = await getVideoSource(theme);

    const currentResolved = video.currentSrc || video.src;
    const targetResolved = new URL(newSrc, window.location.href).toString();
    if (currentResolved === targetResolved) return;

    isTransitioning = true;
    video.style.opacity = "0";

    window.setTimeout(async () => {
      try {
        await setVideoSrcPreserveTime(newSrc);
      } finally {
        video.style.opacity = "1";
        isTransitioning = false;
      }
    }, 500);
  }

  async function initializeVideo() {
    const theme = (await store.getItem<Theme>("theme")) || "light";
    const initialSrc = await getVideoSource(theme);

    if (!video) return;

    video.src = initialSrc;
    video.load();

    await waitForEvent(video, "canplaythrough");
    await video.play().catch(console.error);
  }

  window.addEventListener("themeChanged", updateVideo);

  initializeVideo()
    .then(() => {
      if (spinner) spinner.style.display = "none";
      if (background) background.classList.add("fade-in");

      if (!isMobile) {
        showToast({
          title: "Loaded",
          icon: "/svgs/check.svg",
          variant: "glass",
          duration: config.toast.duration,
        });
      }

      window.dispatchEvent(new CustomEvent("backgroundLoaded"));
    })
    .catch((err) => {
      console.error(err);
      if (spinner) spinner.style.display = "none";
    });
</script>
